{
  "name": "mini-ide",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "npm run setup:java && npm run setup:java-libs && npm run setup:python",
    "setup:java": "node scripts/download-jdk.js",
    "setup:java-libs": "node scripts/download-java-libs.js",
    "setup:python": "node scripts/download-python.js",
    "dev:frontend": "vite --host",
    "dev:backend": "node server/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.300.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tree-kill": "^1.2.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
